# LinkedIn credentials — never commit .env
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Your own public profile URL
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/furkan-g%C3%BCven-933647216/

# false = visible browser (required for first login / 2FA)
LINKEDIN_HEADLESS=false

# Browser engine: webkit (Safari) or chromium (Chrome). Default: webkit
LINKEDIN_BROWSER=webkit

# true = you log in manually in Safari (recommended for 2FA)
LINKEDIN_MANUAL_LOGIN=true

# Slow motion in ms (debug)
LINKEDIN_SLOW_MO=0
